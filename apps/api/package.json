    "@dmdoc/shared-types": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^11.0.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.34.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.12.0",
    "openai": "^4.77.0",
    "zod": "^3.24.1"
