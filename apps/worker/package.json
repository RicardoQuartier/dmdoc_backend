    "@dmdoc/logger": "workspace:*",
    "@dmdoc/shared-types": "workspace:*",
    "bullmq": "^5.34.0",
    "file-type": "^19.6.0",
    "ioredis": "5.10.1",
    "openai": "^4.93.0",
    "pino": "^9.6.0",
    "postgres": "^3.4.5",
    "tiktoken": "^1.0.21",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
