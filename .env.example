# App
NODE_ENV=development
APP_PORT=5051
LOG_LEVEL=info

# JWT
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=dmdoc

# Redis (BullMQ)
REDIS_URL=redis://localhost:5052

# Storage de arquivos — S3, MinIO (dev) ou Cloudflare R2 (prod alternativo)
#
# Dev local com MinIO (docker-compose):
#   AWS_REGION=us-east-1
#   AWS_S3_BUCKET=dmdoc-documents
#   AWS_ACCESS_KEY_ID=minioadmin
#   AWS_SECRET_ACCESS_KEY=minioadmin
#   S3_ENDPOINT=http://localhost:5054
#   S3_PUBLIC_ENDPOINT=http://localhost:5054   # = S3_ENDPOINT no host; no compose, S3_ENDPOINT é http://minio:9000
#   S3_FORCE_PATH_STYLE=true
#
# Cloudflare R2 (produção):
#   AWS_REGION=auto
#   AWS_S3_BUCKET=dmdoc-documents
#   AWS_ACCESS_KEY_ID=<r2-access-key>
#   AWS_SECRET_ACCESS_KEY=<r2-secret-key>
#   S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   S3_PUBLIC_ENDPOINT=                         # vazio: o endpoint do R2 já é público
#   S3_FORCE_PATH_STYLE=false
#
AWS_REGION=us-east-1
AWS_S3_BUCKET=dmdoc-documents
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_ENDPOINT=
# Endpoint público para assinar URLs de download (browser-reachable). Em dev com
# MinIO via Docker, o S3_ENDPOINT é o host interno (minio:9000) inacessível pelo
# navegador — setar este como a porta publicada. Vazio em produção (R2/S3 já públicos).
S3_PUBLIC_ENDPOINT=
S3_FORCE_PATH_STYLE=false

# Extração de texto
# "python": microserviço unificado (PyMuPDF/docx/xlsx/pptx + EasyOCR) — padrão, dev e prod.
# "unstructured"/"native": legados, mantidos como fallback.
EXTRACTOR=python
# URL do microserviço de extração. No docker-compose dev é http://extractor:8000/extract
# (porta 5056 no host).
EXTRACTOR_URL=http://localhost:5056/extract
# Legado (só quando EXTRACTOR=unstructured):
UNSTRUCTURED_URL=http://localhost:5053/general/v0/general
UNSTRUCTURED_API_KEY=

# LLM
# "openai" para produção, "openrouter" para testes gratuitos
LLM_PROVIDER=openrouter
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=google/gemma-3-27b-it:free

# Embeddings (sempre OpenAI)
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Limites
MAX_UPLOAD_MB=50
CHUNK_TARGET_TOKENS=500
CHUNK_OVERLAP_TOKENS=50

# Atlas Search / Vector Search (create-atlas-indexes)
# O script usa o driver MongoDB nativo (collection.createSearchIndexes) — não
# requer Atlas Admin API. Estas variáveis são reservadas para uso futuro caso
# seja necessário gerenciar índices via Management API diretamente.
# ATLAS_PUBLIC_KEY=
# ATLAS_PRIVATE_KEY=
# ATLAS_PROJECT_ID=
# ATLAS_CLUSTER_NAME=
