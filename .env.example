# App
NODE_ENV=development
APP_PORT=3000
LOG_LEVEL=info

# JWT
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=dmdoc

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Storage de arquivos — S3, MinIO (dev) ou Cloudflare R2 (prod alternativo)
#
# Dev local com MinIO (docker-compose):
#   AWS_REGION=us-east-1
#   AWS_S3_BUCKET=dmdoc-documents
#   AWS_ACCESS_KEY_ID=minioadmin
#   AWS_SECRET_ACCESS_KEY=minioadmin
#   S3_ENDPOINT=http://localhost:9000
#   S3_FORCE_PATH_STYLE=true
#
# Cloudflare R2 (produção):
#   AWS_REGION=auto
#   AWS_S3_BUCKET=dmdoc-documents
#   AWS_ACCESS_KEY_ID=<r2-access-key>
#   AWS_SECRET_ACCESS_KEY=<r2-secret-key>
#   S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   S3_FORCE_PATH_STYLE=false
#
AWS_REGION=us-east-1
AWS_S3_BUCKET=dmdoc-documents
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false

# Extração de texto
# "unstructured" em dev (Docker), "native" em prod sem Docker
EXTRACTOR=unstructured
UNSTRUCTURED_URL=http://localhost:8000/general/v0/general
UNSTRUCTURED_API_KEY=

# LLM
# "openai" para produção, "openrouter" para testes gratuitos
LLM_PROVIDER=openrouter
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=google/gemma-3-27b-it:free

# Embeddings (sempre OpenAI)
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Limites
MAX_UPLOAD_MB=50
CHUNK_TARGET_TOKENS=500
CHUNK_OVERLAP_TOKENS=50

# Atlas Search / Vector Search (create-atlas-indexes)
# O script usa o driver MongoDB nativo (collection.createSearchIndexes) — não
# requer Atlas Admin API. Estas variáveis são reservadas para uso futuro caso
# seja necessário gerenciar índices via Management API diretamente.
# ATLAS_PUBLIC_KEY=
# ATLAS_PRIVATE_KEY=
# ATLAS_PROJECT_ID=
# ATLAS_CLUSTER_NAME=
