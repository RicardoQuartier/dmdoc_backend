{
  "name": "@dmdoc/db-pg",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings=0",
    "migrate": "drizzle-kit migrate",
    "generate": "drizzle-kit generate",
    "seed": "tsx src/seed.ts",
    "db:fresh": "tsx src/db-fresh.ts"
  },
  "dependencies": {
    "@dmdoc/shared-types": "workspace:*",
    "argon2": "^0.41.1",
    "drizzle-orm": "^0.44.2",
    "pgvector": "^0.2.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
